{
  "ci_smoke_direct": {
    "description": "Fast PR smoke test with direct writer mode and loose absolute thresholds. Relative comparison against main is the primary gate.",
    "defaults": {
      "use_spark": false,
      "duration_seconds": 8
    },
    "modes": {
      "insert": {
        "rows_per_second": 250,
        "batch_size": 200,
        "batch_interval_ms": 50,
        "thresholds": {
          "min_success_rate": 99.0,
          "min_throughput_rps": 100.0,
          "max_p95_latency_ms": 4000.0,
          "max_error_count": 0
        }
      },
      "upsert": {
        "rows_per_second": 200,
        "batch_size": 150,
        "batch_interval_ms": 75,
        "thresholds": {
          "min_success_rate": 99.0,
          "min_throughput_rps": 75.0,
          "max_p95_latency_ms": 5000.0,
          "max_error_count": 0
        }
      },
      "bulk-insert": {
        "rows_per_second": 1000,
        "batch_size": 1000,
        "batch_interval_ms": 200,
        "thresholds": {
          "min_success_rate": 99.0,
          "min_throughput_rps": 400.0,
          "max_p95_latency_ms": 8000.0,
          "max_error_count": 0
        }
      }
    }
  },
  "ci_smoke_hermetic": {
